{
  "name": "@devlog-mcp/core",
  "version": "0.1.0",
  "description": "Developer logging and workspace management MCP servers for multiple AI CLIs (based on MCP SDK v1.17.1)",
  "license": "MIT",
  "author": "Pawel Pawlowski",
  "homepage": "https://github.com/byPawel/devlog-mcp",
  "bugs": "https://github.com/byPawel/devlog-mcp/issues",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byPawel/devlog-mcp.git"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "modelcontextprotocol",
    "mcp",
    "devlog",
    "developer-tools",
    "logging",
    "claude",
    "gemini",
    "qwen3"
  ],
  "exports": {
    "./*": {
      "import": "./dist/esm/*",
      "require": "./dist/cjs/*"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/esm/*"
      ]
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "devlog": "./bin/devlog.js"
  },
  "scripts": {
    "devlog": "tsx src/devlog-cli.ts",
    "devlog:init": "tsx src/devlog-cli.ts init",
    "devlog:migrate": "tsx src/devlog-cli.ts migrate",
    "devlog:cleanup": "tsx scripts/cleanup.ts",
    "fetch:spec-types": "curl -o spec.types.ts https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/refs/heads/main/schema/2025-06-18/schema.ts",
    "build": "npm run build:esm && npm run build:servers",
    "build:esm": "mkdir -p dist/esm && echo '{\"type\": \"module\"}' > dist/esm/package.json && tsc -p tsconfig.prod.json",
    "build:esm:w": "npm run build:esm -- -w",
    "build:cjs": "mkdir -p dist/cjs && echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json && tsc -p tsconfig.cjs.json",
    "build:cjs:w": "npm run build:cjs -- -w",
    "build:servers": "mkdir -p dist/servers && cp dist/esm/servers/*.js dist/servers/",
    "examples:simple-server:w": "tsx --watch src/examples/server/simpleStreamableHttp.ts --oauth",
    "prepack": "npm run build:esm && npm run build:cjs",
    "lint": "eslint src/",
    "test": "npm run fetch:spec-types && jest",
    "start": "npm run server",
    "server": "tsx watch --clear-screen=false src/cli.ts server",
    "client": "tsx src/cli.ts client",
    "dev:core": "tsx watch src/servers/core-server.ts",
    "dev:search": "tsx watch src/servers/search-server.ts",
    "dev:planning": "tsx watch src/servers/planning-server.ts",
    "dev:analytics": "tsx watch src/servers/analytics-server.ts",
    "server:core": "node bin/devlog-core.js",
    "server:search": "node bin/devlog-search.js",
    "server:planning": "node bin/devlog-planning.js",
    "server:analytics": "node bin/devlog-analytics.js",
    "server:unified": "node dist/esm/servers/unified-server.js",
    "serve": "tsx src/servers/unified-server.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.23.0",
    "ajv": "^6.12.6",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.5",
    "drizzle-orm": "^0.45.1",
    "eventsource": "^3.0.2",
    "eventsource-parser": "^3.0.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "glob": "^11.0.3",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.6.0",
    "ink-gradient": "^3.0.0",
    "pkce-challenge": "^5.0.0",
    "raw-body": "^3.0.0",
    "react": "^19.2.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@jest-mock/express": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/content-type": "^1.1.8",
    "@types/cors": "^2.8.17",
    "@types/cross-spawn": "^6.0.6",
    "@types/eslint__js": "^8.42.3",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.32",
    "@types/react": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.12",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.8.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "ws": "^8.18.0"
  },
  "resolutions": {
    "strip-ansi": "6.0.1"
  }
}
