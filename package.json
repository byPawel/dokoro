{
  "name": "dokoro",
  "version": "0.2.0",
  "description": "Multi-layer agent-memory MCP server (working, episodic, semantic, procedural, affective) for Claude Code and any MCP client.",
  "license": "MIT",
  "author": "Pawel Pawlowski",
  "homepage": "https://github.com/byPawel/dokoro",
  "bugs": "https://github.com/byPawel/dokoro/issues",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byPawel/dokoro.git"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "modelcontextprotocol",
    "mcp",
    "dokoro",
    "developer-tools",
    "logging",
    "claude",
    "gemini",
    "qwen3"
  ],
  "exports": {
    "./*": "./dist/esm/*"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/esm/*"
      ]
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "dokoro": "./bin/dokoro.js"
  },
  "scripts": {
    "dokoro": "tsx src/dokoro-cli.ts",
    "dokoro:init": "tsx src/dokoro-cli.ts init",
    "dokoro:migrate": "tsx src/dokoro-cli.ts migrate",
    "dokoro:cleanup": "tsx scripts/cleanup.ts",
    "build": "npm run build:esm",
    "build:esm": "mkdir -p dist/esm && echo '{\"type\": \"module\"}' > dist/esm/package.json && tsc -p tsconfig.prod.json",
    "build:esm:w": "npm run build:esm -- -w",
    "prepack": "npm run build:esm",
    "lint": "eslint src/",
    "test": "jest",
    "test:site": "node site/compare-table.test.mjs",
    "start": "npm run server:core",
    "dev:core": "tsx watch src/servers/core-server.ts",
    "dev:search": "tsx watch src/servers/search-server.ts",
    "dev:planning": "tsx watch src/servers/planning-server.ts",
    "dev:analytics": "tsx watch src/servers/analytics-server.ts",
    "server:core": "node bin/dokoro-core.js",
    "server:search": "node bin/dokoro-search.js",
    "server:planning": "node bin/dokoro-planning.js",
    "server:analytics": "node bin/dokoro-analytics.js",
    "server:unified": "node dist/esm/servers/unified-server.js",
    "serve": "tsx src/servers/unified-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "^6.12.6",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.5",
    "drizzle-orm": "^0.45.1",
    "eventsource": "^3.0.2",
    "eventsource-parser": "^3.0.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "glob": "^11.0.3",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.6.0",
    "ink-gradient": "^3.0.0",
    "pkce-challenge": "^5.0.0",
    "raw-body": "^3.0.0",
    "react": "^19.2.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.1"
  },
  "optionalDependencies": {
    "@lancedb/lancedb": "^0.23.0",
    "apache-arrow": "^18.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@jest-mock/express": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/content-type": "^1.1.8",
    "@types/cors": "^2.8.17",
    "@types/cross-spawn": "^6.0.6",
    "@types/eslint__js": "^8.42.3",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.32",
    "@types/react": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.12",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.8.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "ws": "^8.18.0"
  },
  "resolutions": {
    "strip-ansi": "6.0.1"
  }
}
